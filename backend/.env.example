# ---- Server ----
PORT=5000
NODE_ENV=production

# Frontend origin(s) allowed by CORS. Single value or comma-separated list.
# Example: https://sharanee.vercel.app
CLIENT_URL=http://localhost:5173

# ---- MongoDB ----
# MongoDB Atlas connection string (create a free M0 cluster at mongodb.com/atlas).
# Example: mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/sharanee?retryWrites=true&w=majority
MONGO_URI=

# ---- JWT ----
# Use a long random string. Generate one with:  openssl rand -base64 32
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRE=7d

# ---- Email (optional) ----
# Leave blank to print emails to the server log instead of sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Sharanee <no-reply@sharanee.com>

# ---- Cloudinary (image hosting) ----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
